# ===========================================
# VARIÁVEIS DE AMBIENTE - MINDSTEPS BACKEND
# ===========================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES

# Supabase Database
DATABASE_URL=https://seu-projeto.supabase.co
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima
SUPABASE_SERVICE_KEY=sua-chave-de-servico

# JWT Secret (use uma string aleatória forte)
JWT_SECRET=sua-chave-secreta-muito-forte-aqui

# OpenAI API Key
OPENAI_API_KEY=sua-chave-openai

# Server Port (não precisa mudar, Render define automaticamente)
PORT=3001